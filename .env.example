TOKEN_FLOW_DB=token_flow.db
# Base URL of this token-flow service — snapshots are pushed to /token-data/push after writes
# (used by the push_client; should match the service's own PORT)
TOKEN_FLOW_UI_URL=http://localhost:8001
ANTHROPIC_API_KEY=sk-ant-...
S3_BUCKET=my-token-flow-bucket
AWS_DEFAULT_REGION=us-west-2
PORT=8001
MEMORY_DIR=/home/ec2-user/.openclaw/workspace/memory
WORKSPACE=/home/ec2-user/.openclaw/workspace
SESSIONS_DIR=
