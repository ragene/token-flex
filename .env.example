TOKEN_FLOW_DB=token_flow.db
# URL of the token-flow service that hosts /token-data/push — snapshots are broadcast to WS clients
# In production this is the ALB DNS name. For local dev use http://localhost:8001
TOKEN_FLOW_UI_URL=https://token-flow-api.thefreightdawg.com
ANTHROPIC_API_KEY=sk-ant-...
S3_BUCKET=my-token-flow-bucket
AWS_DEFAULT_REGION=us-west-2
PORT=8001
MEMORY_DIR=/home/ec2-user/.openclaw/workspace/memory
WORKSPACE=/home/ec2-user/.openclaw/workspace
SESSIONS_DIR=
